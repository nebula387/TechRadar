# === Telegram ===
# Get from @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=
# Channel username (e.g. @mychannel) or numeric ID
TELEGRAM_CHANNEL_ID=
# Your personal chat ID for previews -- get from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=
# Approve posts before publishing? (true/false)
ENABLE_APPROVAL_MODE=false
# Seconds to wait for approval (0 = wait forever)
APPROVAL_TIMEOUT_SECONDS=600

# === GitHub ===
# Optional: raises rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=

# === LLM (free tier only) ===
# Groq -- used for filtering (fast, free)
# Get key at https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b

# NVIDIA NIM -- fallback if Groq quota exhausted
# Free credits on signup: https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenRouter -- used for content generation (free models only)
# Get key at https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# === Instagram ===
# Requires Meta Developer App + Instagram Business Account
# https://developers.facebook.com/docs/instagram-api
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# === Reddit (optional, enable later) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# === Twitter / X (optional, enable later) ===
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# === LinkedIn (optional, enable later) ===
LINKEDIN_ACCESS_TOKEN=

# === Quality ===
MIN_SCORE=85
MAX_POSTS_PER_DAY=3
MAX_TELEGRAM_POSTS_PER_DAY=1

# === Channel toggles ===
ENABLE_TELEGRAM=true
ENABLE_INSTAGRAM=false
ENABLE_WEBSITE=true
ENABLE_REDDIT=false
ENABLE_TWITTER=false
ENABLE_LINKEDIN=false

# === Website ===
WEBSITE_OUTPUT_DIR=./website/public
WEBSITE_BASE_URL=https://nebula387.github.io/TechRadar
