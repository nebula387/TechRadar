# ─── Telegram ──────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your channel username (e.g. @techradar_ai_ru) or numeric chat ID
TELEGRAM_CHANNEL_ID=
# Your personal chat ID for receiving previews — get from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=
# Set to true to review content before publishing
ENABLE_APPROVAL_MODE=false
# Seconds to wait for approval before giving up (0 = wait forever)
APPROVAL_TIMEOUT_SECONDS=600

# ─── GitHub ────────────────────────────────────────────────────
# Optional, increases API rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=

# ─── LLM — FREE TIER ONLY ──────────────────────────────────────
# Groq: fast inference, used for filtering
# Create at https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: content generation, always use :free models
# Create at https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ─── Instagram ─────────────────────────────────────────────────
# Requires a Meta Developer App with Instagram Graph API
# https://developers.facebook.com/docs/instagram-api
# Your page-backed Instagram account ID (numeric)
INSTAGRAM_ACCOUNT_ID=
# Long-lived access token (60-day expiry, refresh monthly)
INSTAGRAM_ACCESS_TOKEN=

# ─── Reddit (optional, enable later) ──────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ─── X / Twitter (optional, enable later) ─────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── LinkedIn (optional, enable later) ────────────────────────
LINKEDIN_ACCESS_TOKEN=

# ─── Quality Settings ──────────────────────────────────────────
MIN_SCORE=85
MAX_POSTS_PER_DAY=3

# ─── Channel toggles ───────────────────────────────────────────
ENABLE_TELEGRAM=true
ENABLE_INSTAGRAM=false
ENABLE_WEBSITE=true
ENABLE_REDDIT=false
ENABLE_TWITTER=false
ENABLE_LINKEDIN=false

# ─── Website ───────────────────────────────────────────────────
WEBSITE_OUTPUT_DIR=./website/public
# Set to your GitHub Pages URL after first deploy
# Format: https://<username>.github.io/<repo-name>
WEBSITE_BASE_URL=https://nebula387.github.io/TechRadar
